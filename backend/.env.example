# ─── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cxoorbit_db
DB_USER=root
DB_PASSWORD=''

# ─── JWT ──────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Email (SMTP) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=noreply@cxoorbitglobal.com

# ─── Frontend URL (CORS) ──────────────────────
CLIENT_URL=http://localhost:3000
